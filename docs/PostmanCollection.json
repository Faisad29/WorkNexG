{
  "info": {
    "name": "WorkNexG API",
    "description": "Complete API collection for WorkNexG Workforce Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"My Company Ltd\",\n  \"name\": \"Admin User\",\n  \"email\": \"admin@company.com\",\n  \"phone\": \"+966500000000\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"country\": \"KSA\",\n  \"timezone\": \"Asia/Riyadh\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@worknexg.test\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Sites",
      "item": [
        {
          "name": "List Sites",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/sites"
          }
        },
        {
          "name": "Create Site",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/sites",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jeddah Branch\",\n  \"latitude\": 21.4858,\n  \"longitude\": 39.1925,\n  \"radius_meters\": 200,\n  \"is_active\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "List Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/employees?page=1&status=active",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "status", "value": "active" },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_code\": \"EMP-0002\",\n  \"full_name\": \"Sara Al-Otaibi\",\n  \"phone\": \"+966501234567\",\n  \"email\": \"sara@company.com\",\n  \"nationality\": \"Saudi\",\n  \"job_title\": \"HR Manager\",\n  \"role\": \"hr\",\n  \"salary_type\": \"monthly\",\n  \"base_salary\": 9500,\n  \"join_date\": \"2026-01-01\",\n  \"contract_end_date\": \"2027-01-01\",\n  \"status\": \"active\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "List Attendance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/attendance?date=2026-06-06",
              "query": [{ "key": "date", "value": "2026-06-06" }]
            }
          }
        },
        {
          "name": "Check In",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/attendance/check-in",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": \"{{employee_id}}\",\n  \"site_id\": \"{{site_id}}\",\n  \"attendance_date\": \"2026-06-06\",\n  \"check_in_time\": \"2026-06-06T08:00:00\",\n  \"check_in_latitude\": 24.7136,\n  \"check_in_longitude\": 46.6753\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Check Out",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/attendance/check-out",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": \"{{employee_id}}\",\n  \"attendance_date\": \"2026-06-06\",\n  \"check_out_time\": \"2026-06-06T17:00:00\",\n  \"check_out_latitude\": 24.7136,\n  \"check_out_longitude\": 46.6753\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Payroll",
      "item": [
        {
          "name": "List Payrolls",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/payroll"
          }
        },
        {
          "name": "Generate Payroll",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/payroll/generate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"month\": 6,\n  \"year\": 2026\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Approve Payroll",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/payroll/{{payroll_id}}/approve"
          }
        },
        {
          "name": "Lock Payroll",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/payroll/{{payroll_id}}/lock"
          }
        },
        {
          "name": "Mark Paid",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/payroll/{{payroll_id}}/pay"
          }
        }
      ]
    },
    {
      "name": "Leave",
      "item": [
        {
          "name": "List Leave Requests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/leave"
          }
        },
        {
          "name": "Submit Leave Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/leave",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": \"{{employee_id}}\",\n  \"leave_type\": \"annual\",\n  \"start_date\": \"2026-07-01\",\n  \"end_date\": \"2026-07-07\",\n  \"reason\": \"Family vacation\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Compliance",
      "item": [
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/documents"
          }
        },
        {
          "name": "Add Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/documents",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": \"{{employee_id}}\",\n  \"type\": \"iqama\",\n  \"document_number\": \"2380001234\",\n  \"issue_date\": \"2024-01-01\",\n  \"expiry_date\": \"2026-12-31\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/notifications/send",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"email\",\n  \"recipient\": \"employee@company.com\",\n  \"message\": \"Your Iqama expires in 7 days. Please renew.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
